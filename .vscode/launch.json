    "version": "0.2.0",
    "configurations": [
    
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "DeviceServiceApplication",
            "request": "launch",
            "mainClass": "com.bidcast.device_service.DeviceServiceApplication",
            "projectName": "device-service"
        },
        {
            "type": "java",
            "name": "UserServiceApplication",
            "request": "launch",
            "mainClass": "com.bidcast.user_service.UserServiceApplication",
            "projectName": "user-service",
            "args": [
                "--spring.profiles.active=dev"
            ]
        }
    ]
}
